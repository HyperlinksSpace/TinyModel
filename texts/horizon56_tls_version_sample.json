    { "offered_tls_version": "tls1.2", "expect_allow": true },
    { "offered_tls_version": "TLS1.3", "expect_allow": true },
    { "offered_tls_version": "tls1.0", "expect_allow": false },
    { "offered_tls_version": "tls1.1", "expect_allow": false }
  ]
}
