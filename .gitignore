.env
# Local training / Hub download scratch (never commit model weights)
.tmp/
.venv/
__pycache__/
*.pyc
dist/
build/
artifacts/**/.gitkeep
# Local eval smoke output (train_tinymodel1_classifier.py --output-dir artifacts/eval-smoke)
artifacts/eval-smoke/
artifacts/emotion-smoke/
artifacts/finetune-smoke/
# Phase 1 generated run outputs (large local artifacts)
artifacts/phase1/runs/
# Horizon 1 three-dataset trained weights (summary is in texts/)
artifacts/horizon1/three-tasks/
artifacts/horizon1/three-tasks-summary.json
# Horizon 2 local run outputs (regenerable; handbook keeps usage)
.tmp/horizon2/
.tmp/horizon2-verify/
artifacts/horizon2/
# Horizon 3 SQLite memory DBs (default under .tmp/horizon3)
.tmp/horizon3/
artifacts/horizon3/
# Horizon 4 CLIP / verify output
.tmp/horizon4/
.tmp/horizon4-verify/
.tmp/horizon4-verify-pretrained/
artifacts/horizon4/
# Horizon 6–7 local smoke (regenerable)
.tmp/horizon6-converge/
.tmp/horizon7-assured/
artifacts/horizon6/
artifacts/horizon7/
.tmp/horizon8-probe/
.tmp/horizon9-policy/
artifacts/horizon8/
artifacts/horizon9/
# Local debug/runtime crash files
debug.log
texts/debug.log
*.stackdump
